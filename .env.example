# ╔══════════════════════════════════════════════════════════════╗
# ║         PLAYBEAT DIGITAL — ENVIRONMENT VARIABLES            ║
# ║  Copy this file to .env and fill in your values             ║
# ║  NEVER commit .env to version control                       ║
# ╚══════════════════════════════════════════════════════════════╝

# ── SERVER ───────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
BASE_URL=http://localhost:3000

# ── DATABASE ─────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/playbeat?retryWrites=true&w=majority

# ── AUTH ─────────────────────────────────────────────────────────
JWT_SECRET=replace-with-long-random-secret-at-least-64-chars
SESSION_SECRET=replace-with-another-long-random-secret

# ── ADMIN ────────────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-strong-password

# ── STRIPE ───────────────────────────────────────────────────────
# Get keys from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLIC_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── JAZZCASH ─────────────────────────────────────────────────────
JAZZCASH_MERCHANTID=
JAZZCASH_PASSWORD=
JAZZCASH_HASHKEY=
JAZZCASH_SANDBOX_URL=https://sandbox.jazzcash.com.pk/CustomerPortal/transactionmanagement/merchantform/
JAZZCASH_PRODUCTION_URL=https://payments.jazzcash.com.pk/CustomerPortal/transactionmanagement/merchantform/
JAZZCASH_PAYMENTMODE=sandbox

# ── BANK ALFALAH ─────────────────────────────────────────────────
ALFAPAY_API_URL=https://sandbox.bankalfalah.com/HS/api/HSAPI/HSAPI
ALFAPAY_MODE=sandbox
ALFAPAY_CHANNEL_ID=1002
ALFAPAY_MERCHANT_ID=197
ALFAPAY_STORE_ID=000001
ALFAPAY_RETURN_URL=${BASE_URL}/api/payments/callback/alfalah
ALFAPAY_MERCHANT_USERNAME=
ALFAPAY_MERCHANT_PASSWORD=
ALFAPAY_MERCHANT_HASH=
ALFAPAY_KEY_1=
ALFAPAY_KEY_2=

# ── MEEZAN BANK ──────────────────────────────────────────────────
MEZPAY_USERNAME=
MEZPAY_PASSWORD=

# ── EMAIL (SMTP) ─────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=support@playbeat.pk
SMTP_PASS=your-app-password

# ── ALLOWED ORIGINS (comma-separated) ───────────────────────────
ALLOWED_ORIGINS=https://playbeat.pk,http://localhost:3000
