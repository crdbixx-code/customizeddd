# Base URL of the PlayBeat Express backend (no trailing slash).
# Leave empty to use the same origin the client is served from (recommended in production
# when the Express server also serves the built client, e.g. via `npm run build` + static hosting).
# For local development with `npm run dev` (Vite on :5173) pointing at the Express API on :3000:
VITE_API_URL=http://localhost:3000
